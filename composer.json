{
    "name": "ptplugins/filament-pivot-table-free",
    "description": "Free pivot table Blade component for FilamentPHP. Group Eloquent records into a 2-dimensional pivot with Sum aggregation. Works with Filament 3, 4, and 5.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "filament",
        "filamentphp",
        "laravel",
        "pivot-table",
        "blade-component",
        "eloquent"
    ],
    "homepage": "https://ptplugins.com/filament-pivot-table",
    "support": {
        "issues": "https://github.com/ptplugins/filament-pivot-table-free/issues",
        "source": "https://github.com/ptplugins/filament-pivot-table-free"
    },
    "authors": [
        {
            "name": "Premtech Plugins",
            "email": "plugins@premte.ch",
            "homepage": "https://ptplugins.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0",
        "illuminate/view": "^10.0 || ^11.0 || ^12.0",
        "illuminate/database": "^10.0 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "PtPlugins\\FilamentPivotTableFree\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PtPlugins\\FilamentPivotTableFree\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "PtPlugins\\FilamentPivotTableFree\\PivotTableFreeServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
